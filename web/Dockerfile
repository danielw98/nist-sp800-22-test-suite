# Multi-stage build. Build context MUST be the spectral-dft-test/ root
# (docker-compose sets context: ..), so that src/, data/ and web/ are visible.
#
# Stage 1 compiles the C++ binaries for the runtime (Linux/musl, statically
# linked against libstdc++). Stage 2 builds the Next.js standalone bundle from
# web/ (using the data-static/ + public/ that `pnpm gen` produced locally before
# deploy). Stage 3 is the minimal runtime with the binaries + data files.

# ---- Stage 1: C++ binaries -------------------------------------------------
FROM alpine:3.20 AS cpp
RUN apk add --no-cache build-base cmake ninja
WORKDIR /cpp
COPY CMakeLists.txt ./
COPY src ./src
COPY tests ./tests
RUN cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_EXE_LINKER_FLAGS="-static-libstdc++ -static-libgcc" \
 && cmake --build build --target nist_test nist_assess

# ---- Stage 2: Next.js build ------------------------------------------------
FROM node:20-alpine AS build
RUN npm install -g pnpm@10
WORKDIR /app
COPY web/package.json web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY web ./
# next build uses the committed data-static/ + public/ (regenerated by `pnpm gen`
# locally before deploy). `pnpm exec` skips the prebuild lifecycle hook.
RUN pnpm exec next build

# ---- Stage 3: runtime ------------------------------------------------------
FROM node:20-alpine AS runner
RUN apk add --no-cache libstdc++
WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0 \
    DFT_BIN_DIR=/app/bin \
    DFT_DATA_DIR=/app/data
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public
COPY --from=cpp /cpp/build/nist_test /app/bin/nist_test
COPY --from=cpp /cpp/build/nist_assess /app/bin/nist_assess
COPY data /app/data
EXPOSE 3000
CMD ["node", "server.js"]
